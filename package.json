{
  "name": "liverun",
  "version": "0.5.5",
  "description": "A simple tool for live reloading during development. This package should be installed as a devDependency.",
  "author": {
    "name": "Alex Nordin",
    "url": "https://alexnordin.dev"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "homepage": "https://nordinalex.github.io/liverun",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NordinAlex/liverun.git"
  },
  "bugs": {
    "url": "https://github.com/NordinAlex/liverun/issues"
  },
  "keywords": [
    "auto-reload",
    "chokidar",
    "dev-tool",
    "development-tool",
    "express",
    "file-watch",
    "hot-reload",
    "live-reload",
    "node",
    "proxy",
    "reload",
    "terminal",
    "watch",
    "websocket"
  ],
  "type": "module",
  "bin": {
    "liverun": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsup src/cli/index.ts --format esm --watch",
    "build": "tsup src/cli/index.ts --format esm --clean",
    "test": "vitest run"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "http-proxy-middleware": "^4.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/node": "^25.6.2",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
